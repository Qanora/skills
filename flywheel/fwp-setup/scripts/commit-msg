#!/bin/bash
# Git hook: require issue reference in commit messages.
# Install: ln -sf ../../scripts/commit-msg .git/hooks/commit-msg

COMMIT_MSG=$(cat "$1")

if ! echo "$COMMIT_MSG" | grep -qE '#[0-9]+'; then
    echo "BLOCKED: Commit message must reference at least one issue (e.g. '#1', 'closes #2')." >&2
    exit 1
fi

exit 0
